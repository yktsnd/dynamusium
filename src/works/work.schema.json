{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yktsnd.github.io/dynamusium/schemas/work.schema.json",
  "title": "DynaMusium Work Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "slug",
    "title",
    "subtitle",
    "gallery",
    "runtime",
    "render",
    "kernel",
    "tier",
    "year",
    "authors",
    "summary",
    "question",
    "equation",
    "duration",
    "parameters",
    "presets",
    "citations"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "title": { "type": "string", "minLength": 2 },
    "subtitle": { "type": "string", "minLength": 4 },
    "gallery": {
      "enum": ["motion-chaos", "matter-pattern", "life-reaction", "earth-climate", "cosmos-gravity"]
    },
    "runtime": {
      "enum": ["reaction-network-v1", "ode-v1", "field-v1", "discrete-v1", "analytic-v1"]
    },
    "render": { "enum": ["phase", "orbit", "field", "series"] },
    "kernel": { "type": "string", "minLength": 2 },
    "tier": { "enum": ["flagship", "collection"] },
    "year": { "type": "string", "minLength": 1 },
    "authors": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "summary": { "type": "string", "minLength": 40 },
    "question": { "type": "string", "minLength": 20 },
    "equation": { "type": "string", "minLength": 5 },
    "duration": { "type": "number", "exclusiveMinimum": 0 },
    "parameters": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "symbol", "min", "max", "step", "default"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "symbol": { "type": "string" },
          "min": { "type": "number" },
          "max": { "type": "number" },
          "step": { "type": "number", "exclusiveMinimum": 0 },
          "default": { "type": "number" }
        }
      }
    },
    "presets": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "values"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "values": { "type": "object", "additionalProperties": { "type": "number" } }
        }
      }
    },
    "citations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "url"],
        "properties": {
          "label": { "type": "string" },
          "url": { "type": "string", "format": "uri", "pattern": "^https://" }
        }
      }
    }
  }
}
